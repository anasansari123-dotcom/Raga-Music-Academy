# Public site URL (metadata, payment links, sitemap)
NEXT_PUBLIC_SITE_URL=https://www.ragavedaacademy.com

# Auth.js / NextAuth v5
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=https://www.ragavedaacademy.com
# NEXTAUTH_URL is also accepted as an alias for AUTH_URL

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_DB_NAME=raga-veda

# Seed / reset admin (local scripts only)
ADMIN_EMAIL=admin@ragavedaacademy.com
ADMIN_PASSWORD=change-me-after-first-login
ADMIN_NAME=Academy Admin
ADMIN_PHONE=+919136593977

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Optional: protect /api/check in production
CHECK_SECRET=

# Optional: contact email via SMTP
SMTP_USER=
SMTP_PASS=
CONTACT_TO=
